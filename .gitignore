# ---------------------------------------------------------------------------
# Project data (large, licensed, or regenerable)
#
# Anchor the rules with a leading slash so they only match the top-level
# data/ and outputs/ directories — NOT src/buildings_shanghai/data/ etc.
#
# Ignore the *contents* of each data subdirectory (data/raw/*) rather than
# the directory itself; git cannot re-include a file inside a directory
# that is fully excluded, so the !data/raw/README.md exception below would
# silently do nothing if we wrote `data/` instead of `data/raw/*`.
# ---------------------------------------------------------------------------
/data/raw/*
/data/interim/*
/data/processed/*
/outputs/
/weather/*.epw
/weather/*.stat
/weather/*.ddy

# Keep the README explaining the raw-data layout
!/data/raw/README.md
# Track the validation-set working directory and its deliverables
# (README, workbook, README_working.md are per-run outputs that must
# be reproducible and reviewable in the PR).
!/data/raw/validation/
!/data/raw/validation/**
# But do not track the *internal* candidates table (carries `height` and
# breaks the §5 blind-test rule if leaked) or the checkpoint-1 preview PNGs
# (large, run-time regenerable).
/data/raw/validation/working/candidates_internal.parquet
/data/raw/validation/working/checkpoint1/
# The KML carries footprint outer rings from the licensed commercial
# dataset — local-only, regenerate via the emit stage.
/data/raw/validation/working/validation_pins.kml

